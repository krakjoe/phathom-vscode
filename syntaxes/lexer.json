{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "phathom Lexer",
    "scopeName": "source.phathom-lexer",
    "fileTypes": ["lexer"],
    "patterns": [
        { "include": "#comment" },
        { "include": "#section" },
        { "include": "#pattern_line" },
        { "include": "#skip_line" },
        { "include": "#generic_key" }
    ],
    "repository": {

        "comment": {
            "comment": "INI-style ; line comment",
            "name": "comment.line.semicolon.phathom-lexer",
            "match": ";.*$"
        },

        "section": {
            "comment": "Token type declaration [TOKEN_NAME]",
            "name": "meta.section.phathom-lexer",
            "match": "^[ \\t]*(\\[)([a-zA-Z_][a-zA-Z0-9_]*)(\\])",
            "captures": {
                "1": { "name": "punctuation.definition.section.begin.phathom-lexer" },
                "2": { "name": "entity.name.class.token.phathom-lexer" },
                "3": { "name": "punctuation.definition.section.end.phathom-lexer" }
            }
        },

        "pattern_line": {
            "comment": "pattern = /regex/ or pattern = \"/regex/\"",
            "name": "meta.pattern-value.phathom-lexer",
            "begin": "^[ \\t]*(pattern)[ \\t]*(=)[ \\t]*",
            "end": "$",
            "beginCaptures": {
                "1": { "name": "keyword.other.key.pattern.phathom-lexer" },
                "2": { "name": "punctuation.separator.key-value.phathom-lexer" }
            },
            "patterns": [
                { "include": "#comment" },
                { "include": "#regex_quoted" },
                { "include": "#regex_unquoted" }
            ]
        },

        "skip_line": {
            "comment": "skip = true|false",
            "name": "meta.skip-value.phathom-lexer",
            "match": "^[ \\t]*(skip)[ \\t]*(=)[ \\t]*(true|false)\\b",
            "captures": {
                "1": { "name": "keyword.other.key.skip.phathom-lexer" },
                "2": { "name": "punctuation.separator.key-value.phathom-lexer" },
                "3": { "name": "constant.language.boolean.phathom-lexer" }
            }
        },

        "generic_key": {
            "comment": "Any other key = value pair",
            "name": "meta.key-value.phathom-lexer",
            "match": "^[ \\t]*([a-zA-Z_][a-zA-Z0-9_]*)[ \\t]*(=)",
            "captures": {
                "1": { "name": "keyword.other.key.phathom-lexer" },
                "2": { "name": "punctuation.separator.key-value.phathom-lexer" }
            }
        },

        "regex_quoted": {
            "comment": "Quoted form: \"/regex/flags\"",
            "name": "string.regexp.quoted.phathom-lexer",
            "begin": "\"/",
            "end": "/[imsxuADSXJU]*\"",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.regexp.begin.phathom-lexer" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.regexp.end.phathom-lexer" }
            },
            "contentName": "string.regexp.content.phathom-lexer"
        },

        "regex_unquoted": {
            "comment": "Unquoted form: /regex/flags",
            "name": "string.regexp.unquoted.phathom-lexer",
            "begin": "/",
            "end": "/[imsxuADSXJU]*",
            "beginCaptures": {
                "0": { "name": "punctuation.definition.regexp.begin.phathom-lexer" }
            },
            "endCaptures": {
                "0": { "name": "punctuation.definition.regexp.end.phathom-lexer" }
            },
            "contentName": "string.regexp.content.phathom-lexer"
        }
    }
}
